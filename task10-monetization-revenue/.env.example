# Server Execution Ports
PORT=3009
NODE_ENV=development

# Core Database Persistence Layer (Supabase Postgres)
SUPABASE_URL=supabase_url
SUPABASE_SERVICE_ROLE_KEY=supabse-service-role-key

# Third-Party Payment Gateway Integration (Razorpay)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=azorpay-test-secret

# Operational Monetization Switch 
# Set to 'false' for sandbox/staging testing; set to 'true' for production live-money mode [cite: 102]
IS_REAL_MONEY_MODE=false